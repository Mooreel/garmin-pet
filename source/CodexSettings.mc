class CodexSettings {
    function bridgeUrl() {
        return CODEX_BRIDGE_URL;
    }

    function autoRefresh() {
        return CODEX_AUTO_REFRESH;
    }

    function hapticAlerts() {
        return CODEX_HAPTIC_ALERTS;
    }

    function petName() {
        return CODEX_PET_DISPLAY_NAME;
    }

    function colorSurface() {
        return CODEX_THEME_SURFACE;
    }

    function colorPanel() {
        return CODEX_THEME_PANEL;
    }

    function colorSelection() {
        return CODEX_THEME_SELECTION;
    }

    function colorInk() {
        return CODEX_THEME_INK;
    }

    function colorSubtle() {
        return CODEX_THEME_SUBTLE;
    }

    function colorAccent() {
        return CODEX_THEME_ACCENT;
    }

    function colorReview() {
        return CODEX_THEME_REVIEW;
    }

    function colorGood() {
        return CODEX_THEME_GOOD;
    }

    function colorWarn() {
        return CODEX_THEME_WARN;
    }
}
